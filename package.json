{
  "name": "medit-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Medit - Markdown Editor Monorepo",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @medit/tauri dev",
    "build": "pnpm --filter @medit/tauri build",
    "tauri:dev": "pnpm --filter @medit/tauri tauri:dev",
    "tauri:build": "pnpm --filter @medit/tauri tauri:build",
    "build:chrome": "pnpm --filter @markdown-viewer/core build:chrome",
    "build:firefox": "pnpm --filter @markdown-viewer/core build:firefox",
    "build:vscode": "pnpm --filter @markdown-viewer/core build:vscode",
    "typecheck": "pnpm -r typecheck"
  },
  "keywords": [
    "markdown",
    "editor",
    "tauri",
    "desktop"
  ],
  "author": {
    "name": "hubo1989"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hubo1989/Medit.git"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  }
}
